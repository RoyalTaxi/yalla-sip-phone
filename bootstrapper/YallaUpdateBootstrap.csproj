<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- TFM is plain net8.0 (not net8.0-windows) because Program.cs only uses
         cross-platform System.* APIs. This lets us cross-compile from macOS/Linux
         to win-x64 without the Windows Desktop workload. -->
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>YallaUpdateBootstrap</RootNamespace>
    <AssemblyName>yalla-update-bootstrap</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <!-- Self-contained + single-file + trimmed = one fat .exe, ~15 MB,
         no .NET runtime dependency on the operator machine. We cannot
         assume .NET 8 Desktop Runtime is pre-installed on operator
         Windows PCs. This inflates the bootstrapper from 171 KB to
         ~15 MB — negligible inside a 140 MB MSI. -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>partial</TrimMode>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>
</Project>
